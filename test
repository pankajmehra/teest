// ===============================
// 5) ADD DOUBLE-CLICK METHOD IN SEARCH PAGE XAML.CS
// ===============================

private async void DataGrid_DoubleTapped(object sender, DoubleTappedRoutedEventArgs e)
{
    if (DataGrid.SelectedItem is not GroupHoldoverTableSearchResult selectedRow)
        return;

    var editModel = new GroupHoldOverModel
    {
        // important: this makes API update instead of insert
        GroupHoldoverTableId = selectedRow.GroupHoldoverId,

        Source = selectedRow.Source,

        ParentEmployerGroupId = selectedRow.ParentEmployerGroupId,
        ParentEmployerGroupUd = selectedRow.ParentEmployerGroupUd,

        EmployerGroupId = selectedRow.EmployerGroupId,
        EmployerGroupUd = selectedRow.EmployerGroupUd,

        GroupContractId = selectedRow.GroupContractId,
        GroupContractUd = selectedRow.GroupContractUd,

        BenefitPlanId = selectedRow.BenefitPlanId,
        BenefitPlanUd = selectedRow.BenefitPlanUd,

        EffectiveDate = selectedRow.EffectiveDate,
        ThruDate = selectedRow.ThruDate,

        UseReceiveDate = selectedRow.UseReceiveDate,
        UseIncurredDate = selectedRow.UseIncurDate,

        Comment = selectedRow.Comment
    };

    var dialogVm = new GroupHoldoverDialogViewModel(
        _autoSuggestService,
        editModel);

    var dialog = new GroupHoldoverDialog(dialogVm)
    {
        XamlRoot = this.XamlRoot
    };

    await dialog.ShowAsync();

    if (!dialog.IsCancelRequested && dialog.ViewModel.GroupHoldoverRow != null)
    {
        await ViewModel.UpdateAsync(
            dialog.ViewModel.GroupHoldoverRow,
            selectedRow);
    }
}


// ===============================
// 6) ADD UpdateAsync TO SEARCH VIEWMODEL
// ===============================

public async Task UpdateAsync(
    GroupHoldOverModel model,
    GroupHoldoverTableSearchResult existingRow)
{
    try
    {
        IsBusy = true;

        // same API as add, but GroupHoldoverTableId > 0 means update
        var response = await _provider.AddGroupHoldoverAsync(model);

        if (response.IsSuccess)
        {
            existingRow.Source = response.Value.Source;

            existingRow.ParentEmployerGroupId = response.Value.ParentEmployerGroupId;
            existingRow.ParentEmployerGroupUd = response.Value.ParentEmployerGroupUd;

            existingRow.EmployerGroupId = response.Value.EmployerGroupId;
            existingRow.EmployerGroupUd = response.Value.EmployerGroupUd;

            existingRow.GroupContractId = response.Value.GroupContractId;
            existingRow.GroupContractUd = response.Value.GroupContractUd;

            existingRow.BenefitPlanId = response.Value.BenefitPlanId;
            existingRow.BenefitPlanUd = response.Value.BenefitPlanUd;

            existingRow.EffectiveDate = response.Value.EffectiveDate;
            existingRow.ThruDate = response.Value.ThruDate;

            existingRow.UseReceiveDate = response.Value.UseReceiveDate;
            existingRow.UseIncurDate = response.Value.UseIncurredDate;

            existingRow.Comment = response.Value.Comment;

            await _dialogService.ShowAsync(
                "Success - Modify Record",
                "Record updated successfully.");
        }
        else
        {
            await _dialogService.ShowAsync(
                "Error - Modify Record",
                "Unable to update record.");
        }
    }
    finally
    {
        IsBusy = false;
    }
}
