public GroupHoldoverDialogViewModel(
    IGroupHoldoverAutoSuggestService autoSuggestService,
    GroupHoldOverModel existingRecord)
{
    _autoSuggestService = autoSuggestService;

    GroupHoldoverRow = existingRecord;

    IsEditMode = true;
}


