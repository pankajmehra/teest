public async Task<List<GroupHoldoverTableSearchResult>> GetGroupHoldoverTableSearchResults(
    GroupHoldoverTableSearchCriteria criteria)
{
    var query = new Dictionary<string, string>();

    if (criteria.ParentEmployerGroupId.HasValue)
        query["ParentEmployerGroupId"] = criteria.ParentEmployerGroupId.Value.ToString();

    if (criteria.GroupHoldoverTableId.HasValue)
        query["GroupHoldoverTableId"] = criteria.GroupHoldoverTableId.Value.ToString();

    if (criteria.EmployerGroupID.HasValue)
        query["EmployerGroupID"] = criteria.EmployerGroupID.Value.ToString();

    if (criteria.GroupContractID.HasValue)
        query["GroupContractID"] = criteria.GroupContractID.Value.ToString();

    if (criteria.BenefitPlanID.HasValue)
        query["BenefitPlanID"] = criteria.BenefitPlanID.Value.ToString();

    if (!string.IsNullOrWhiteSpace(criteria.EffectiveDate))
        query["EffectiveDate"] = criteria.EffectiveDate;

    if (!string.IsNullOrWhiteSpace(criteria.ThruDate))
        query["ThruDate"] = criteria.ThruDate;

    if (!string.IsNullOrWhiteSpace(criteria.Comment))
        query["Comment"] = criteria.Comment;

    var queryString = string.Join("&", query.Select(x =>
        $"{Uri.EscapeDataString(x.Key)}={Uri.EscapeDataString(x.Value)}"));

    var url = "/api/benefit-administration/GroupHoldoverTool/Group-holdover";

    if (!string.IsNullOrWhiteSpace(queryString))
        url += "?" + queryString;

    return await _apiClient.GetAsync2<List<GroupHoldoverTableSearchResult>>(new Uri(url, UriKind.Relative));
}
