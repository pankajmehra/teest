public class LookupSuggestion
{
    public int Id { get; set; }
    public string? DisplayText { get; set; }
}


// ==========================
// 6. USAGE - BOTH SCREENS
// ==========================

// SuggestionChosen
private void AutoSuggest_SuggestionChosen(
    AutoSuggestBox sender,
    AutoSuggestBoxSuggestionChosenEventArgs args)
{
    if (args.SelectedItem is not LookupSuggestion selected)
        return;

    sender.Text = selected.DisplayText;

    // SEARCH PAGE:
    AutoSuggestSelectionHelper.ApplySelection(
        sender.Tag?.ToString(),
        selected,
        ViewModel.SearchCriteria);

    // DIALOG:
    // AutoSuggestSelectionHelper.ApplySelection(
    //     sender.Tag?.ToString(),
    //     selected,
    //     ViewModel.GroupHoldoverRow);
}


// TextChanged
private async void AutoSuggest_TextChanged(
    AutoSuggestBox sender,
    AutoSuggestBoxTextChangedEventArgs args)
{
    if (args.Reason != AutoSuggestionBoxTextChangeReason.UserInput)
        return;

    // SEARCH PAGE:
    AutoSuggestSelectionHelper.ClearSelectionId(
        sender.Tag?.ToString(),
        ViewModel.SearchCriteria);

    // DIALOG:
    // AutoSuggestSelectionHelper.ClearSelectionId(
    //     sender.Tag?.ToString(),
    //     ViewModel.GroupHoldoverRow);

    var text = sender.Text?.Trim() ?? string.Empty;

    if (text.Length < 4)
    {
        sender.ItemsSource = null;
        return;
    }

    sender.ItemsSource = await ViewModel.GetLookupSuggestionsAsync(
        sender.Tag?.ToString(),
        text);
}
