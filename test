<UserControl
    x:Class="WebTPA.GeneralManagement.DesktopUI.Features.Shared.EmployergroupSearch.EmployergroupSearch"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d"
    Loaded="UserControl_Loaded"
    PreviewKeyUp="UserControl_PreviewKeyUp">
    
    <UserControl.Resources>
        <ResourceDictionary Source="ms-appx:///Microsoft.UI.Xaml/DensityStyles/Compact.xaml" />
    </UserControl.Resources>
    
    <Grid Padding="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <!--First row-->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <!--First column-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MaxWidth="300"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                
                <TextBox AccessKey="I" Header="Employer Group UD"
                        Text="{x:Bind ViewModel.SearchCriteria.EmployergroupUd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        x:Name="EmployergroupUdTextBox"
                        ToolTipService.ToolTip="Employer Group UD is a short identifier for the group that the plan is linked to.The * symbol can be used as a wildcard operator if required."/>
                
                <TextBox AccessKey="M" Grid.Column="1" Margin="3 0 0 0" Header="Name"
                        Text="{x:Bind ViewModel.SearchCriteria.EmployergroupNm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTipService.ToolTip="Name is a short identifier for the group that the plan is linked to. The * symbol can be used as a wildcard operator if required."/>

                <TextBox Grid.Column="0" Grid.Row="1" Header="Parent Group UD"
                        Text="{x:Bind ViewModel.SearchCriteria.ParentName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTipService.ToolTip="Parent Group UD is a short identifier for the group that the plan is linked to. The * symbol can be used as a wildcard operator if required."/>

                <ComboBox x:Name="ClientClassification" Header="Client Classification: "
                          Margin="3 0 0 0"
                          Grid.Column="1" Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.ClientClassificationLookup}"
                          HorizontalAlignment="Stretch"
                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                          DisplayMemberPath="Name"
                          SelectedValuePath="EmployergroupClientClassificationTypeId"
                          SelectedItem="{x:Bind ViewModel.SelectedClientClassification, Mode = TwoWay, UpdateSourceTrigger = PropertyChanged}"
                          SelectedValue="{x:Bind ViewModel.ClientClassificationId, Mode = TwoWay, UpdateSourceTrigger = PropertyChanged}"/>
            </Grid>
            <!--Second column-->
            <StackPanel Grid.Column="1" Margin="10 25 0 0">
                <Button x:Name="SearchButton" Width="100"
                        AccessKey="S"
                        Content="Search"
                        Command="{x:Bind ViewModel.SearchCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>
                <Button Name="ClearButton" Width="100" AccessKey="L" Content="Clear" Margin="0 5 0 0" Click="ClearButton_Click"/>

            </StackPanel>
        </Grid>
        <!--second row-->
        <Grid Grid.Row="1">
            <TextBlock Text="{x:Bind ViewModel.SearchResultCount, Mode=OneWay}" Margin="3 3 0 0"/>
        </Grid>
        <!--third row-->
        <controls:DataGrid x:Name="DataGrid"
                           Grid.Row="2"
                           Margin="0 10 0 5"
                           ItemsSource="{x:Bind ViewModel.Employergroups}"
                           SelectedItem="{x:Bind ViewModel.SelectedEmployergroup, Mode=TwoWay}"
                           VerticalAlignment="Stretch"
                           HorizontalAlignment="Stretch"
                           HorizontalScrollBarVisibility="Visible"
                           VerticalScrollBarVisibility="Visible"
                           AreRowDetailsFrozen="False"
                           AreRowGroupHeadersFrozen="True"
                           AutoGenerateColumns="False"
                           CanUserSortColumns="True"
                           Sorting="DataGrid_Sorting"
                           CanUserReorderColumns="False"
                           CanUserResizeColumns="True"
                           ColumnHeaderHeight="32"
                           MaxColumnWidth="400"
                           FrozenColumnCount="0"
                           GridLinesVisibility="None"
                           HeadersVisibility="Column"
                           IsReadOnly="True"
                           RowDetailsVisibilityMode="Collapsed"
                           SelectionMode="Single"
                           RowGroupHeaderPropertyNameAlternative="Range"
                           DoubleTapped="DataGrid_DoubleTapped"
                           KeyUp="DataGrid_KeyUp"
                           PreviewKeyDown="DataGrid_PreviewKeyDown">
            <controls:DataGrid.Resources>
                <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush" Color="Transparent"/>
                <SolidColorBrush x:Key="DataGridCellFocusVisualSecondaryBrush" Color="Transparent"/>
            </controls:DataGrid.Resources>
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Employer Group UD" Tag="EmployergroupUd" Binding="{Binding EmployergroupUd}" MinWidth="100"/>
                <controls:DataGridTextColumn x:Name="NameColumn" Header="Employer Group Name" Tag="EmployergroupNm" Binding="{Binding EmployergroupNm}" MinWidth="300"/>
                <controls:DataGridTextColumn Header="Parent Group UD" Tag="ParentName" Binding="{Binding ParentName}" MinWidth="100"/>
                <controls:DataGridTextColumn Header="Client Classification" Tag="ClientClassification" Binding="{Binding ClientClassification}"/>
            </controls:DataGrid.Columns>
        </controls:DataGrid>
        <!--Loading shade-->
        <Grid Grid.Row="2" Visibility="{x:Bind ViewModel.SearchCommand.IsRunning, Mode=OneWay}">
            <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Opacity=".8"></Grid>
            <!--<Grid>-->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <ProgressRing Margin="0 0 10 0" Width="25" Height="25" VerticalAlignment="Center"/>
                    <TextBlock Text="Searching..." FontSize="14" VerticalAlignment="Center"/>
                    <Button Content="Cancel" Margin="5 0 0 0" Width="65" 
                            Click="{x:Bind ViewModel.SearchCommand.Cancel}"
                            VerticalAlignment="Center"/>
                </StackPanel>
            <!--</Grid>-->
        </Grid>
    </Grid>
</UserControl>
