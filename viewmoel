using Microsoft.UI.Xaml.Controls;

namespace WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover.Helpers
{
    public static class AutoSuggestHelper
    {
        public static bool ShouldSearch(AutoSuggestBoxTextChangedEventArgs args, string? text, int minLength = 4)
        {
            return args.Reason == AutoSuggestionBoxTextChangeReason.UserInput
                && !string.IsNullOrWhiteSpace(text)
                && text.Trim().Length >= minLength;
        }

        public static string GetSafeText(string? text)
        {
            return text?.Trim() ?? string.Empty;
        }
    }
}


// ==========================
