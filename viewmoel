private void SetSelected(string? type, LookupSuggestion? value)
{
    switch (type)
    {
        case "ParentGroupUD":
            ViewModel.SelectedParentEmployerGroupUD = value;
            break;

        case "EmployerGroupUD":
            ViewModel.SelectedEmployerGroupUD = value;
            break;

        case "Contract":
            ViewModel.SelectedGroupContractUD = value;
            break;

        case "Benefit":
            ViewModel.SelectedBenefitPlanUd = value;
            break;
    }
}

public static class AutoSuggestHelper
{
    public static void ApplySelection(
        string? type,
        LookupSuggestion selected,
        IGroupHoldoverLookupModel model)
    {
        switch (type)
        {
            case "ParentGroupUD":
                model.ParentEmployerGroupId = selected.Id;
                model.ParentEmployerGroupUd = selected.DisplayText;
                break;

            case "EmployerGroupUD":
                model.EmployerGroupId = selected.Id;
                model.EmployerGroupUd = selected.DisplayText;
                break;

            case "Contract":
                model.GroupContractId = selected.Id;
                model.GroupContractUd = selected.DisplayText;
                break;

            case "Benefit":
                model.BenefitPlanId = selected.Id;
                model.BenefitPlanUd = selected.DisplayText;
                break;
        }
    }

    public static async Task<LookupSuggestion?> ResolveTypedSuggestionAsync(
        string? type,
        string text,
        Func<string?, string, Task<List<LookupSuggestion>>> getSuggestionsAsync)
    {
        if (string.IsNullOrWhiteSpace(text))
            return null;

        var suggestions = await getSuggestionsAsync(type, text);

        return suggestions.FirstOrDefault(x =>
            string.Equals(x.DisplayText, text, StringComparison.OrdinalIgnoreCase));
    }
}

private async void AutoSuggest_QuerySubmitted(
    AutoSuggestBox sender,
    AutoSuggestBoxQuerySubmittedEventArgs args)
{
    var type = sender.Tag?.ToString();
    var text = sender.Text?.Trim() ?? string.Empty;

    if (string.IsNullOrWhiteSpace(text))
        return;

    var selected = args.ChosenSuggestion as LookupSuggestion;

    // User typed/pasted instead of selecting from dropdown
    if (selected == null)
    {
        selected = await AutoSuggestHelper.ResolveTypedSuggestionAsync(
            type,
            text,
            ViewModel.GetLookupSuggestionsAsync);
    }

    // Still no match found
    if (selected == null)
    {
        SetSelected(type, null);
        ViewModel.RefreshCanSearch();
        return;
    }

    sender.Text = selected.DisplayText;

    IGroupHoldoverLookupModel model = ViewModel.SearchCriteria;
    // For dialog use:
    // IGroupHoldoverLookupModel model = ViewModel.GroupHoldoverRow;

    AutoSuggestHelper.ApplySelection(type, selected, model);
    SetSelected(type, selected);
IGroupHoldoverLookupModel model = ViewModel.GroupHoldoverRow;
    sender.ItemsSource = null;
    ViewModel.RefreshCanSearch();
}
