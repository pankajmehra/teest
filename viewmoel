public DateTimeOffset EffectiveDateValue
{
    get => SearchCriteria.EffectiveDate ?? DateTimeOffset.Now;
    set => SearchCriteria.EffectiveDate = value;
}

public DateTimeOffset ThruDateValue
{
    get => SearchCriteria.ThruDate ?? DateTimeOffset.Now;
    set => SearchCriteria.ThruDate = value;
}

<DatePicker
    Header="Effective Date"
    Date="{x:Bind ViewModel.EffectiveDateValue, Mode=TwoWay}" />

<DatePicker
    Header="Thru Date"
    Date="{x:Bind ViewModel.ThruDateValue, Mode=TwoWay}" />
