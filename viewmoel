// ==========================
using WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover.Models;

namespace WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover.Validation
{
    public static class GroupHoldoverValidator
    {
        public static string? Validate(GroupHoldoverEditModel model)
        {
            if (string.IsNullOrWhiteSpace(model.ParentEmployerGroupUd) &&
                string.IsNullOrWhiteSpace(model.EmployerGroupUd) &&
                string.IsNullOrWhiteSpace(model.GroupContractUd) &&
                string.IsNullOrWhiteSpace(model.BenefitPlanUd))
            {
                return "Enter at least one search criteria.";
            }

            if (model.EffectiveDate.HasValue &&
                model.ThruDate.HasValue &&
                model.ThruDate < model.EffectiveDate)
            {
                return "Thru Date cannot be earlier than Effective Date.";
            }

            return null;
        }
    }
}


