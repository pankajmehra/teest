using Microsoft.UI.Xaml.Controls;
using WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover.Helpers;
using WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover.Models;
using WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover.Validation;

namespace WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover.Dialogs
{
    public sealed partial class GroupHoldoverDialog : ContentDialog
    {
        public GroupHoldoverEditModel Result { get; private set; } = new();

        public GroupHoldoverDialog()
        {
            InitializeComponent();
        }

        private async void AutoSuggest_TextChanged(AutoSuggestBox sender, AutoSuggestBoxTextChangedEventArgs args)
        {
            var text = AutoSuggestHelper.GetSafeText(sender.Text);

            if (!AutoSuggestHelper.ShouldSearch(args, text))
            {
                sender.ItemsSource = null;
                return;
            }

            var results = await GetSuggestionsAsync(text);
            sender.ItemsSource = results;
        }

        private void AutoSuggest_SuggestionChosen(AutoSuggestBox sender, AutoSuggestBoxSuggestionChosenEventArgs args)
        {
            if (args.SelectedItem is LookupSuggestion item)
            {
                sender.Text = item.DisplayText;
            }
        }

        private void ContentDialog_PrimaryButtonClick(ContentDialog sender, ContentDialogButtonClickEventArgs args)
        {
            var model = new GroupHoldoverEditModel
            {
                ParentEmployerGroupUd = ParentBox.Text,
                EmployerGroupUd = EmployerBox.Text,
                GroupContractUd = ContractBox.Text,
                BenefitPlanUd = BenefitBox.Text,
                EffectiveDate = EffectiveDatePicker.Date,
                ThruDate = ThruDatePicker.Date
            };

            var error = GroupHoldoverValidator.Validate(model);
            if (!string.IsNullOrEmpty(error))
            {
                args.Cancel = true;
                ErrorTextBlock.Text = error;
                return;
            }

            Result = model;
        }

        private async Task<List<LookupSuggestion>> GetSuggestionsAsync(string text)
        {
            await Task.Delay(100);

            return new List<LookupSuggestion>
            {
                new() { DisplayText = text + "001" },
                new() { DisplayText = text + "002" }
            };
        }
    }
}


