using System.Collections.ObjectModel;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover.Models;
using WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover.Services;

namespace WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover
{
    public class GroupHoldoverViewModel : INotifyPropertyChanged
    {
        private readonly IGroupHoldoverDataProvider _dataProvider;

        public event PropertyChangedEventHandler? PropertyChanged;

        private void OnPropertyChanged([CallerMemberName] string? name = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(name));
        }

        public GroupHoldoverViewModel(IGroupHoldoverDataProvider dataProvider)
        {
            _dataProvider = dataProvider;
        }

        // Grid data
        public ObservableCollection<GroupHoldoverRow> Results { get; } = new();

        // Selected row
        private GroupHoldoverRow? _selected;
        public GroupHoldoverRow? Selected
        {
            get => _selected;
            set
            {
                _selected = value;
                OnPropertyChanged();
                OnPropertyChanged(nameof(CanDelete));
            }
        }

        // Delete button enabled only when a row is selected and not deleting
        private bool _isDeleting;
        public bool IsDeleting
        {
            get => _isDeleting;
            set
            {
                _isDeleting = value;
                OnPropertyChanged();
                OnPropertyChanged(nameof(CanDelete));
            }
        }

        public bool CanDelete => Selected != null && !IsDeleting;

        public async Task DeleteSelectedAsync(CancellationToken cancellationToken = default)
        {
            if (Selected == null)
                return;

            var itemToDelete = Selected;

            try
            {
                IsDeleting = true;

                // API call first
                await _dataProvider.DeleteGroupHoldoverAsync(itemToDelete.GroupHoldoverId, cancellationToken);

                // Remove from grid only after successful API delete
                Results.Remove(itemToDelete);

                // Reset selection
                Selected = null;
            }
            finally
            {
                IsDeleting = false;
            }
        }
    }
}


