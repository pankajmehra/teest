using Microsoft.UI.Xaml;
using Microsoft.UI.Xaml.Controls;

namespace WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover
{
    public sealed partial class GroupHoldoverSearchPage : Page
    {
        public GroupHoldoverViewModel ViewModel { get; }

        public GroupHoldoverSearchPage(GroupHoldoverViewModel viewModel)
        {
            ViewModel = viewModel;
            this.InitializeComponent();
        }

        private async void Delete_Click(object sender, RoutedEventArgs e)
        {
            if (ViewModel.Selected == null)
                return;

            var dialog = new ContentDialog
            {
                Title = "Confirm Delete",
                Content = "Are you sure you want to delete this record?",
                PrimaryButtonText = "Delete",
                CloseButtonText = "Cancel",
                DefaultButton = ContentDialogButton.Close,
                XamlRoot = this.XamlRoot
            };

            var result = await dialog.ShowAsync();

            if (result != ContentDialogResult.Primary)
                return;

            try
            {
                await ViewModel.DeleteSelectedAsync();
            }
            catch (Exception ex)
            {
                var errorDialog = new ContentDialog
                {
                    Title = "Delete Failed",
                    Content = ex.Message,
                    CloseButtonText = "OK",
                    XamlRoot = this.XamlRoot
                };

                await errorDialog.ShowAsync();
            }
        }
    }
}


