using Microsoft.UI.Xaml;
using Microsoft.UI.Xaml.Controls;
using WebTPA.GeneralManagement.Core.Features.BenefitAdministration.HoldoverTable;

namespace WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover
{
    public sealed partial class GroupHoldoverDialog : ContentDialog
    {
        public GroupHoldOverModel Result { get; private set; } = new();

        public bool IsDeleteRequested { get; private set; }

        public GroupHoldoverDialog()
        {
            InitializeComponent();
        }

        private async void AutoSuggest_TextChanged(AutoSuggestBox sender, AutoSuggestBoxTextChangedEventArgs args)
        {
            if (args.Reason != AutoSuggestionBoxTextChangeReason.UserInput)
                return;

            var text = sender.Text?.Trim() ?? string.Empty;

            if (text.Length < 4)
            {
                sender.ItemsSource = null;
                return;
            }

            sender.ItemsSource = await GetSuggestionsAsync(sender.Tag?.ToString(), text);
        }

        private void AutoSuggest_SuggestionChosen(AutoSuggestBox sender, AutoSuggestBoxSuggestionChosenEventArgs args)
        {
            if (args.SelectedItem is LookupSuggestion item)
                sender.Text = item.DisplayText;
        }

        private void SaveButton_Click(object sender, RoutedEventArgs e)
        {
            if (!HasAtLeastOneUd())
            {
                ErrorTextBlock.Text = "Enter at least one of Parent Employer Group UD, Employer Group UD, Group Contract UD, or Benefit Plan UD.";
                return;
            }

            if (string.IsNullOrWhiteSpace(CommentTextBox.Text))
            {
                ErrorTextBlock.Text = "Comment is required.";
                return;
            }

            Result = new GroupHoldOverModel
            {
                ParentEmployerGroupUd = ParentEmployerGroupUdBox.Text?.Trim(),
                EmployerGroupUd = EmployerGroupUdBox.Text?.Trim(),
                GroupContractUd = GroupContractUdBox.Text?.Trim(),
                BenefitPlanUd = BenefitPlanUdBox.Text?.Trim(),
                EffectiveDate = EffectiveDatePicker.Date,
                ThruDate = ThruDatePicker.Date,
                UseReceiveDate = UseReceivedDateCheckBox.IsChecked,
                UseIncurredDate = UseIncurredDateCheckBox.IsChecked
            };

            Hide();
        }

        private void DeleteButton_Click(object sender, RoutedEventArgs e)
        {
            IsDeleteRequested = true;
            Hide();
        }

        private void ContentDialog_PrimaryButtonClick(ContentDialog sender, ContentDialogButtonClickEventArgs args)
        {
            // intentionally unused because custom Save button is used
        }

        private bool HasAtLeastOneUd()
        {
            return !string.IsNullOrWhiteSpace(ParentEmployerGroupUdBox.Text)
                || !string.IsNullOrWhiteSpace(EmployerGroupUdBox.Text)
                || !string.IsNullOrWhiteSpace(GroupContractUdBox.Text)
                || !string.IsNullOrWhiteSpace(BenefitPlanUdBox.Text);
        }

        private async Task<List<LookupSuggestion>> GetSuggestionsAsync(string? type, string text)
        {
            await Task.Delay(150);

            return new List<LookupSuggestion>
            {
                new() { Id = "1", DisplayText = text + "001" },
                new() { Id = "2", DisplayText = text + "002" },
                new() { Id = "3", DisplayText = text + "003" }
            };
        }
    }

    public class LookupSuggestion
    {
        public string? Id { get; set; }
        public string? DisplayText { get; set; }
    }
}
