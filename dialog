<!-- FILE: GroupHoldoverDialog.xaml -->
<ContentDialog
    x:Class="WebTPA.GeneralManagement.DesktopUI.Features.BenefitAdministrator.GroupHoldover.GroupHoldoverDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add New Record"
    PrimaryButtonText=""
    CloseButtonText=""
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

    <ScrollViewer>
        <StackPanel Spacing="14" Width="760">

            <TextBlock Text="Fields with an asterisk (*) are required"
                       FontStyle="Italic"/>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Source"/>
                <TextBlock Text="mcrdc"/>
            </StackPanel>

            <TextBlock Text="Must enter information for at least one (1) of the below fields"
                       FontStyle="Italic"/>

            <Grid RowSpacing="10" ColumnSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Parent Employer Group UD *" VerticalAlignment="Center"/>
                <AutoSuggestBox x:Name="ParentEmployerGroupUdBox"
                                Grid.Row="0" Grid.Column="1"
                                PlaceholderText="Search"
                                TextChanged="AutoSuggest_TextChanged"
                                SuggestionChosen="AutoSuggest_SuggestionChosen"
                                Tag="Parent"
                                DisplayMemberPath="DisplayText">
                    <AutoSuggestBox.QueryIcon>
                        <SymbolIcon Symbol="Find"/>
                    </AutoSuggestBox.QueryIcon>
                </AutoSuggestBox>

                <TextBlock Grid.Row="1" Grid.Column="1" Text="or" HorizontalAlignment="Center" FontStyle="Italic"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Employer Group UD *" VerticalAlignment="Center"/>
                <AutoSuggestBox x:Name="EmployerGroupUdBox"
                                Grid.Row="2" Grid.Column="1"
                                PlaceholderText="Search"
                                TextChanged="AutoSuggest_TextChanged"
                                SuggestionChosen="AutoSuggest_SuggestionChosen"
                                Tag="Employer"
                                DisplayMemberPath="DisplayText">
                    <AutoSuggestBox.QueryIcon>
                        <SymbolIcon Symbol="Find"/>
                    </AutoSuggestBox.QueryIcon>
                </AutoSuggestBox>

                <TextBlock Grid.Row="3" Grid.Column="1" Text="or" HorizontalAlignment="Center" FontStyle="Italic"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Group Contract UD *" VerticalAlignment="Center"/>
                <AutoSuggestBox x:Name="GroupContractUdBox"
                                Grid.Row="4" Grid.Column="1"
                                PlaceholderText="Search"
                                TextChanged="AutoSuggest_TextChanged"
                                SuggestionChosen="AutoSuggest_SuggestionChosen"
                                Tag="Contract"
                                DisplayMemberPath="DisplayText">
                    <AutoSuggestBox.QueryIcon>
                        <SymbolIcon Symbol="Find"/>
                    </AutoSuggestBox.QueryIcon>
                </AutoSuggestBox>

                <TextBlock Grid.Row="5" Grid.Column="1" Text="or" HorizontalAlignment="Center" FontStyle="Italic"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Benefit Plan UD *" VerticalAlignment="Center"/>
                <AutoSuggestBox x:Name="BenefitPlanUdBox"
                                Grid.Row="6" Grid.Column="1"
                                PlaceholderText="Search"
                                TextChanged="AutoSuggest_TextChanged"
                                SuggestionChosen="AutoSuggest_SuggestionChosen"
                                Tag="Benefit"
                                DisplayMemberPath="DisplayText">
                    <AutoSuggestBox.QueryIcon>
                        <SymbolIcon Symbol="Find"/>
                    </AutoSuggestBox.QueryIcon>
                </AutoSuggestBox>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Effective Date" VerticalAlignment="Center"/>
                <DatePicker x:Name="EffectiveDatePicker" Grid.Row="7" Grid.Column="1"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Thru Date" VerticalAlignment="Center"/>
                <DatePicker x:Name="ThruDatePicker" Grid.Row="8" Grid.Column="1"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="80">
                <CheckBox x:Name="UseReceivedDateCheckBox" Content="Use Received Date"/>
                <CheckBox x:Name="UseIncurredDateCheckBox" Content="Use Incurred Date"/>
            </StackPanel>

            <TextBox x:Name="CommentTextBox"
                     Header="Comment*"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="80"/>

            <TextBlock x:Name="ErrorTextBlock"
                       Foreground="Red"
                       TextWrapping="Wrap"/>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Save"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="SaveButton_Click"/>

                <Button Grid.Column="1"
                        Content="Delete"
                        HorizontalAlignment="Stretch"
                        Click="DeleteButton_Click"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>

