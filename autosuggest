        private async void AutoSuggest_TextChanged(AutoSuggestBox sender, AutoSuggestBoxTextChangedEventArgs args)
        {
            var text = sender.Text?.Trim() ?? string.Empty;

            switch (sender.Tag)
            {
                case "ParentGroupUD":
                    if (ViewModel.SelectedParentEmployerGroupUD?.DisplayText != text)
                    {
                        ViewModel.SearchCriteria.ParentEmployerGroupID = null;
                        ViewModel.SelectedParentEmployerGroupUD = null;
                    }

                    ViewModel.SearchCriteria.ParentEmployerGroupUd = text;

                    break;
                case "EmployerGroupUD":
                    if (ViewModel.SelectedEmployerGroupUD?.DisplayText != text)
                    {
                        ViewModel.SelectedEmployerGroupUD = null;
                        ViewModel.SearchCriteria.EmployerGroupID = null;
                    }

                    ViewModel.SearchCriteria.EmployerGroupUd = text;

                    break;
                case "Contract":
                    if (ViewModel.SelectedGroupContractUD?.DisplayText != text)
                    {
                        ViewModel.SelectedGroupContractUD = null;
                        ViewModel.SearchCriteria.GroupContractID = null;
                    }
                    ViewModel.SearchCriteria.GroupContractUd = text;

                    break;
                case "Benefit":
                    if (ViewModel.SelectedBenefitPlanUd?.DisplayText != text)
                    {
                        ViewModel.SelectedBenefitPlanUd = null;
                        ViewModel.SearchCriteria.BenefitPlanID = null;
                    }
                    ViewModel.SearchCriteria.BenefitPlanUd = text;

                    break;
            }

            var selectedText = sender.Tag switch
            {
                "ParentGroupUD" => ViewModel.SelectedParentEmployerGroupUD?.DisplayText,
                "EmployerGroupUD" => ViewModel.SelectedEmployerGroupUD?.DisplayText,
                "Contract" => ViewModel.SelectedGroupContractUD?.DisplayText,
                "Benefit" => ViewModel.SelectedBenefitPlanUd?.DisplayText,
                _ => null
            };
            if (!string.IsNullOrEmpty(selectedText) && string.Equals(selectedText, text, StringComparison.Ordinal))
            {
                return;
            }
            ViewModel.RefreshCanSearch();
            if (text.Length < 4)
            {
                sender.ItemsSource = null;
                return;
            }
            sender.ItemsSource = await ViewModel.GetLookupSuggestionsAsync(sender.Tag.ToString(), text);

        }

        private void AutoSuggest_SuggestionChosen(AutoSuggestBox sender, AutoSuggestBoxSuggestionChosenEventArgs args)
        {
            if (args.SelectedItem is not LookupSuggestion item)
                return;

            var choosenSuggestion = (LookupSuggestion)args.SelectedItem;

            sender.Text = item.DisplayText;

            switch (sender.Tag)
            {
                case "ParentGroupUD":
                    ViewModel.SelectedParentEmployerGroupUD = choosenSuggestion;
                    break;
                case "EmployerGroupUD":
                    ViewModel.SelectedEmployerGroupUD = choosenSuggestion;
                    break;
                case "Contract":
                    ViewModel.SelectedGroupContractUD = choosenSuggestion;
                    break;
                case "Benefit":
                    ViewModel.SelectedBenefitPlanUd = choosenSuggestion;
                    break;
            }

            ViewModel.RefreshCanSearch();
        }

        private void AutoSuggest_QuerySubmitted(AutoSuggestBox sender, AutoSuggestBoxQuerySubmittedEventArgs args)
        {
            string value = args.ChosenSuggestion is LookupSuggestion item
                ? item.DisplayText!
                : sender.Text;


            var choosenSuggestion = (LookupSuggestion)args.ChosenSuggestion;

            if (choosenSuggestion != null)
            {

                var selectedId = choosenSuggestion.Id;

                switch (sender.Tag)
                {
                    case "ParentGroupUD":
                        ViewModel.SearchCriteria.ParentEmployerGroupUd = value;
                        ViewModel.SearchCriteria.ParentEmployerGroupID = selectedId;
                        ViewModel.SelectedParentEmployerGroupUD = choosenSuggestion;
                        break;
                    case "EmployerGroupUD":
                        ViewModel.SearchCriteria.EmployerGroupUd = value;
                        ViewModel.SearchCriteria.EmployerGroupID = selectedId;
                        ViewModel.SelectedEmployerGroupUD = choosenSuggestion;
                        break;
                    case "Contract":
                        ViewModel.SearchCriteria.GroupContractUd = value;
                        ViewModel.SearchCriteria.GroupContractID = selectedId;
                        ViewModel.SelectedGroupContractUD = choosenSuggestion;
                        break;
                    case "Benefit":
                        ViewModel.SearchCriteria.BenefitPlanUd = value;
                        ViewModel.SearchCriteria.BenefitPlanID = selectedId;
                        ViewModel.SelectedBenefitPlanUd = choosenSuggestion;
                        break;
                }
                isSuggestionSelected = true;
                ViewModel.RefreshCanSearch();
            }
        }



