// =======================
// INTERFACE (COMMON MODEL)
// =======================
public interface IGroupHoldoverLookupModel
{
    int? ParentEmployerGroupId { get; set; }
    string? ParentEmployerGroupUd { get; set; }

    int? EmployerGroupId { get; set; }
    string? EmployerGroupUd { get; set; }

    int? GroupContractId { get; set; }
    string? GroupContractUd { get; set; }

    int? BenefitPlanId { get; set; }
    string? BenefitPlanUd { get; set; }
}

// =======================
// HELPER (REUSABLE LOGIC)
// =======================
public static class AutoSuggestHelper
{
    public static void ClearIfTextChanged(
        string? type,
        string text,
        IGroupHoldoverLookupModel model,
        ref LookupSuggestion? selected)
    {
        if (selected?.DisplayText == text)
            return;

        selected = null;

        switch (type)
        {
            case "ParentGroupUD":
                model.ParentEmployerGroupId = null;
                model.ParentEmployerGroupUd = text;
                break;

            case "EmployerGroupUD":
                model.EmployerGroupId = null;
                model.EmployerGroupUd = text;
                break;

            case "Contract":
                model.GroupContractId = null;
                model.GroupContractUd = text;
                break;

            case "Benefit":
                model.BenefitPlanId = null;
                model.BenefitPlanUd = text;
                break;
        }
    }

    public static void ApplySelection(
        string? type,
        LookupSuggestion selected,
        IGroupHoldoverLookupModel model,
        Action<LookupSuggestion?> setSelected)
    {
        setSelected(selected);

        switch (type)
        {
            case "ParentGroupUD":
                model.ParentEmployerGroupId = selected.Id;
                model.ParentEmployerGroupUd = selected.DisplayText;
                break;

            case "EmployerGroupUD":
                model.EmployerGroupId = selected.Id;
                model.EmployerGroupUd = selected.DisplayText;
                break;

            case "Contract":
                model.GroupContractId = selected.Id;
                model.GroupContractUd = selected.DisplayText;
                break;

            case "Benefit":
                model.BenefitPlanId = selected.Id;
                model.BenefitPlanUd = selected.DisplayText;
                break;
        }
    }
}

// =======================
// PAGE / DIALOG CODE
// =======================

// map selected items
private LookupSuggestion? GetSelected(string? type)
{
    return type switch
    {
        "ParentGroupUD" => ViewModel.SelectedParentEmployerGroupUD,
        "EmployerGroupUD" => ViewModel.SelectedEmployerGroupUD,
        "Contract" => ViewModel.SelectedGroupContractUD,
        "Benefit" => ViewModel.SelectedBenefitPlanUd,
        _ => null
    };
}

private void SetSelected(string? type, LookupSuggestion? value)
{
    switch (type)
    {
        case "ParentGroupUD":
            ViewModel.SelectedParentEmployerGroupUD = value;
            break;
        case "EmployerGroupUD":
            ViewModel.SelectedEmployerGroupUD = value;
            break;
        case "Contract":
            ViewModel.SelectedGroupContractUD = value;
            break;
        case "Benefit":
            ViewModel.SelectedBenefitPlanUd = value;
            break;
    }
}

// =======================
// TEXT CHANGED
// =======================
private async void AutoSuggest_TextChanged(AutoSuggestBox sender, AutoSuggestBoxTextChangedEventArgs args)
{
    if (args.Reason != AutoSuggestionBoxTextChangeReason.UserInput)
        return;

    var type = sender.Tag?.ToString();
    var text = sender.Text?.Trim() ?? "";

    var selected = GetSelected(type);

    // 🔴 CHANGE THIS LINE ONLY depending on screen
    IGroupHoldoverLookupModel model = ViewModel.SearchCriteria; 
    // OR → ViewModel.GroupHoldoverRow

    AutoSuggestHelper.ClearIfTextChanged(type, text, model, ref selected);
    SetSelected(type, selected);

    if (text.Length < 4)
    {
        sender.ItemsSource = null;
        return;
    }

    sender.ItemsSource = await ViewModel.GetLookupSuggestionsAsync(type, text);
}

// =======================
// SUGGESTION CHOSEN
// =======================
private void AutoSuggest_SuggestionChosen(AutoSuggestBox sender, AutoSuggestBoxSuggestionChosenEventArgs args)
{
    if (args.SelectedItem is not LookupSuggestion selected)
        return;

    var type = sender.Tag?.ToString();
    sender.Text = selected.DisplayText;

    IGroupHoldoverLookupModel model = ViewModel.SearchCriteria; 
    // OR → ViewModel.GroupHoldoverRow

    AutoSuggestHelper.ApplySelection(type, selected, model, v => SetSelected(type, v));
}

// =======================
// QUERY SUBMITTED
// =======================
private void AutoSuggest_QuerySubmitted(AutoSuggestBox sender, AutoSuggestBoxQuerySubmittedEventArgs args)
{
    if (args.ChosenSuggestion is not LookupSuggestion selected)
        return;

    var type = sender.Tag?.ToString();
    sender.Text = selected.DisplayText;

    IGroupHoldoverLookupModel model = ViewModel.SearchCriteria; 
    // OR → ViewModel.GroupHoldoverRow

    AutoSuggestHelper.ApplySelection(type, selected, model, v => SetSelected(type, v));
}
